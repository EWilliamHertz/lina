generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Print {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  price       Int?     
  isForSale   Boolean  @default(false)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}